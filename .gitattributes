# Custom merge drivers for conflict resolution
# Specifically target i18n translation files to avoid trailing comma conflicts
resources/i18n/**/*.json merge=json-i18n
packages/backend.ai-ui/src/locale/*.json merge=json-i18n

.github/workflows/*.lock.yml linguist-generated=true merge=ours

# Relay compiler output — deterministically regenerated by `pnpm relay`.
# Mark as generated so GitHub collapses these files in PR diffs (reviewers
# should review the `graphql` tags + schema.graphql, not the compiler output).
react/src/__generated__/** linguist-generated=true
packages/backend.ai-ui/src/__generated__/** linguist-generated=true

# Lockfile — auto-generated by pnpm, never hand-edited (see .claude/rules/pnpm-lockfile-conflicts.md).
pnpm-lock.yaml linguist-generated=true
