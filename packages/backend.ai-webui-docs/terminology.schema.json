{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://backend.ai/webui-docs/terminology.schema.json",
  "title": "Backend.AI WebUI Docs Terminology",
  "description": "Machine-readable source of truth for standardized Backend.AI WebUI user-manual terminology, mirroring TERMINOLOGY.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "languages", "concepts", "avoid"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema/content version of this file.",
      "minimum": 1
    },
    "languages": {
      "type": "array",
      "description": "Languages covered by the manual, in canonical order.",
      "items": {
        "type": "string",
        "enum": ["en", "ko", "ja", "th"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "concepts": {
      "type": "array",
      "description": "Every concept group from TERMINOLOGY.md (Core Concepts, Feature-Specific Terms, User Roles, UI Navigation Terms).",
      "items": { "$ref": "#/definitions/concept" }
    },
    "avoid": {
      "type": "array",
      "description": "Every row of the TERMINOLOGY.md \"Terms to Avoid\" table, one entry per forbidden term.",
      "items": { "$ref": "#/definitions/avoidEntry" }
    }
  },
  "definitions": {
    "language": {
      "type": "string",
      "enum": ["en", "ko", "ja", "th"]
    },
    "preferred": {
      "type": "object",
      "description": "Preferred term per language. A language key is omitted when the source table has no cell for that language.",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "ko": { "type": "string", "minLength": 1 },
        "ja": { "type": "string", "minLength": 1 },
        "th": { "type": "string", "minLength": 1 }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "status", "decidingFR", "preferred"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable kebab-case concept id.",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "category": {
          "type": "string",
          "enum": [
            "Core Concepts",
            "Feature-Specific Terms",
            "User Roles",
            "UI Navigation Terms"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["approved", "deprecated"]
        },
        "decidingFR": {
          "description": "FR-XXXX issue that decided this term, or null when the source cites none.",
          "type": ["string", "null"],
          "pattern": "^FR-[0-9]+$"
        },
        "preferred": { "$ref": "#/definitions/preferred" },
        "context": {
          "type": "string",
          "description": "Optional parenthetical qualifier (e.g. \"Technical term for storage folder\", \"Field label (Resource Group settings)\").",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Optional one-line gloss carried over from the source's explanatory prose.",
          "minLength": 1
        }
      }
    },
    "avoidEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "avoid",
        "useInstead",
        "reason",
        "lang",
        "context",
        "conceptId"
      ],
      "properties": {
        "avoid": {
          "type": "string",
          "description": "The single forbidden term.",
          "minLength": 1
        },
        "useInstead": {
          "type": "string",
          "description": "The canonical replacement term.",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "description": "Why the term is forbidden.",
          "minLength": 1
        },
        "lang": {
          "$ref": "#/definitions/language",
          "description": "Language the avoid rule applies to."
        },
        "context": {
          "description": "Optional parenthetical qualifier (e.g. \"for project\", \"as a UI label\"), or null.",
          "type": ["string", "null"],
          "minLength": 1
        },
        "conceptId": {
          "description": "Optional link to concepts[].id that the canonical replacement maps to, or null.",
          "type": ["string", "null"],
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        }
      }
    }
  }
}
