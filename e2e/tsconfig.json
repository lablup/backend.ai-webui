{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "strict": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"],
    "typeRoots": ["../node_modules/@types"],
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["es6", "dom", "es2016", "es2017", "es2020"]
  },
  "include": ["./**/*"]
}
